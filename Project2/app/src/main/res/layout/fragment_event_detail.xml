<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="250dp">

            <ImageView
                android:id="@+id/ivEventDetailPoster"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/image"
                android:background="#E0E0E0"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="@drawable/gradient_top_shadow"
                android:visibility="gone"/>

            <ImageView
                android:id="@+id/btnBackDetail"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="16dp"
                android:src="@drawable/back_button"
                android:background="@drawable/bg_rounded_white"
                android:padding="8dp"
                android:elevation="4dp"
                android:clickable="true"
                android:foreground="?attr/selectableItemBackground"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvEventDetailCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Category"
                android:background="@drawable/bg_category_chip"
                android:textColor="@color/white"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvEventDetailTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Event Title Here"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvEventDetailOrganizer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="By Organizer Name"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#F9F9F9"
                android:padding="12dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Entry Fee"
                    android:textColor="#333333"
                    android:textSize="16sp"/>

                <TextView
                    android:id="@+id/tvEventDetailFee"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MYR 10.00"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#D32F2F"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="#F9F9F9">

            <TextView
                android:text="Event Details"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#004581"
                android:layout_marginBottom="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp">
                <ImageView android:src="@drawable/calendar" android:layout_width="20dp" android:layout_height="20dp" app:tint="#014B88"/>
                <TextView android:id="@+id/tvDetailDateVal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:text="12 Oct 2023" android:textSize="15sp" android:textColor="#444"/>
            </LinearLayout>

            <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp">
                <ImageView android:src="@drawable/clock" android:layout_width="20dp" android:layout_height="20dp" app:tint="#014B88"/>
                <TextView android:id="@+id/tvDetailTimeVal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:text="10:00 AM" android:textSize="15sp" android:textColor="#444"/>
            </LinearLayout>

            <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp">
                <ImageView android:src="@drawable/pin" android:layout_width="20dp" android:layout_height="20dp" app:tint="#014B88"/>
                <TextView android:id="@+id/tvDetailVenueVal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:text="Dewan A, UTHM" android:textSize="15sp" android:textColor="#444"/>
            </LinearLayout>

            <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="24dp">
                <ImageView android:src="@drawable/profile" android:layout_width="20dp" android:layout_height="20dp" app:tint="#014B88"/>
                <TextView android:id="@+id/tvDetailQuotaVal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:text="Unlimited" android:textSize="15sp" android:textColor="#444"/>
            </LinearLayout>
        </LinearLayout>
            <TextView
                android:text="Starts In"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <LinearLayout
                android:id="@+id/layoutCountdown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#014B88"
                android:padding="16dp"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:id="@+id/llTimerContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <!-- Days -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginEnd="20dp">

                        <TextView
                            android:id="@+id/tvCountDays"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="00"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="#FFF"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Days"
                            android:textColor="#DDD"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <!-- Separator -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=":"
                        android:textColor="#FFF"
                        android:textSize="24sp"
                        android:layout_marginEnd="20dp"/>

                    <!-- Hours -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginEnd="20dp">

                        <TextView
                            android:id="@+id/tvCountHours"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="00"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="#FFF"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hours"
                            android:textColor="#DDD"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <!-- Separator -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=":"
                        android:textColor="#FFF"
                        android:textSize="24sp"
                        android:layout_marginEnd="20dp"/>

                    <!-- Minutes -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvCountMinutes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="00"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="#FFF"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mins"
                            android:textColor="#DDD"
                            android:textSize="12sp"/>
                    </LinearLayout>

                </LinearLayout>


                <TextView
                    android:id="@+id/tvExpiredMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EVENT EXPIRED"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:visibility="gone"/>

            </LinearLayout>

            <Button
                android:id="@+id/btnJoinEvent"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Join Event"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:backgroundTint="#014B88"
                app:cornerRadius="8dp"
                android:stateListAnimator="@null"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <LinearLayout
            android:id="@+id/back_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/imageView2"
                android:layout_width="25dp"
                android:layout_height="25dp"
                app:tint="#004581"
                app:srcCompat="@drawable/back_button" />

            <TextView
                android:id="@+id/back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Back"
                android:textColor="#004581"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Event Details"
            android:textColor="#004A7C"
            android:textSize="32sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/back_button" />

        <LinearLayout
            android:id="@+id/layoutStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTitle">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status    : "
                android:textColor="#000000"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvStatusValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_pending"
                android:paddingHorizontal="16dp"
                android:paddingVertical="4dp"
                android:text="Pending"
                android:textColor="#C7B658"
                android:textStyle="bold"/>
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/mainCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/white"
            app:layout_constraintTop_toBottomOf="@id/layoutStatus">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="120dp"
                    android:background="#EAEAEA"
                    android:padding="12dp"
                    android:text="Loading Event Description..."
                    android:textColor="#333333" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvDetailOrg"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/black"
                        android:text="Organized by   : -"
                        android:padding="4dp"/>

                    <TextView
                        android:id="@+id/tvDetailName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/black"
                        android:text="Name                : -"
                        android:padding="4dp"/>

                    <TextView
                        android:id="@+id/tvDetailCat"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/black"
                        android:text="Category          : -"
                        android:padding="4dp"/>

                    <TextView
                        android:id="@+id/tvDetailDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Date                  : -"
                        android:textColor="@color/black"
                        android:padding="4dp"/>

                    <TextView
                        android:id="@+id/tvDetailTime"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/black"
                        android:text="Time                 : -"
                        android:padding="4dp"/>

                    <TextView
                        android:id="@+id/tvDetailVenue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Venue               : -"
                        android:textColor="@color/black"
                        android:padding="4dp"/>

                    <TextView
                        android:id="@+id/tvEntryFee"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Fee                    : -"
                        android:textColor="@color/black"
                        android:padding="4dp"/>


                    <TextView
                        android:id="@+id/tvDetailQuota"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/black"
                        android:text="Quota               : -"
                        android:padding="4dp"/>

                    <TextView
                        android:id="@+id/tvDetailLink"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/black"
                        android:text="Form Link        : -"
                        android:padding="4dp"
                        android:autoLink="web"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Event Director Details"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#004581"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvDirName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/black"
                        android:text="Name             : -"
                        android:padding="4dp"/>

                    <TextView
                        android:id="@+id/tvDirMatric"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/black"
                        android:text="Matric No       : -"
                        android:padding="4dp"/>

                    <TextView
                        android:id="@+id/tvDirPhone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/black"
                        android:text="Phone No       : -"
                        android:padding="4dp"/>
                </LinearLayout>

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:columnCount="2">

                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_columnWeight="1"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Approval Letter : "
                            android:textColor="@color/black"
                            android:textSize="12sp"/>

                        <Button
                            android:id="@+id/btnViewProposal"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:text="view"
                            android:textColor="#FFFFFF"
                            android:backgroundTint="#004581"
                            android:layout_margin="4dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_columnWeight="1"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Event Poster : "
                            android:textColor="@color/black"
                            android:textSize="12sp"/>

                        <Button
                            android:id="@+id/btnViewPoster"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:text="view"
                            android:textColor="#FFFFFF"
                            android:backgroundTint="#018ABD"
                            android:layout_margin="4dp"/>
                    </LinearLayout>
                </GridLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:id="@+id/layoutApprovalActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/mainCard"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Approval :"
                android:textColor="@color/black"
                android:textSize="18sp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <Button
                    android:id="@+id/btnDetailApprove"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:backgroundTint="#4CAF50"
                    android:text="Approve"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"/>

                <Button
                    android:id="@+id/btnDetailReject"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="#D35F5F"
                    android:text="Reject"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>